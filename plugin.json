{
  "name": "legal-audit-de",
  "version": "1.0.0",
  "description": "Claude Code plugin for German/EU legal audits (DSGVO, TDDDG, UWG, AI Act, DDG, BGB, BFSG, UrhG, MarkenG, NIS2). Scans codebases, live URLs, and individual legal documents; produces severity-classified findings + clean corrected versions. NOT legal advice.",
  "author": {
    "name": "FutureRoots DE",
    "url": "https://github.com/FutureRootsDE"
  },
  "license": "MIT",
  "homepage": "https://github.com/FutureRootsDE/legal-audit-de",
  "repository": {
    "type": "git",
    "url": "https://github.com/FutureRootsDE/legal-audit-de.git"
  },
  "bugs": {
    "url": "https://github.com/FutureRootsDE/legal-audit-de/issues"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "legal",
    "dsgvo",
    "gdpr",
    "privacy",
    "compliance",
    "germany",
    "eu-law",
    "audit",
    "tddg",
    "uwg",
    "ai-act",
    "bdsg",
    "legal-audit"
  ],
  "commands": [
    "legal-audit",
    "legal-audit-live",
    "legal-doc-check",
    "legal-kb",
    "legal-verify",
    "legal-update",
    "legal-status"
  ],
  "agents": [
    "legal-auditor",
    "legal-researcher",
    "legal-text-writer"
  ],
  "skills": [
    "legal-audit-codebase",
    "legal-kb-lookup",
    "legal-verify-experts",
    "legal-update-sources"
  ],
  "hooks": {
    "SessionStart": ".claude/hooks/session_start.py",
    "UserPromptSubmit": ".claude/hooks/prompt_submit.py",
    "PostToolUse": ".claude/hooks/post_write.py"
  },
  "requirements": {
    "claude-code": ">=2.0.0",
    "python": ">=3.10"
  },
  "language": "de",
  "scope": [
    "DE",
    "EU"
  ],
  "disclaimer": "Outputs are NOT legal advice within the meaning of § 2 RDG. Mandatory attorney review before production use."
}
